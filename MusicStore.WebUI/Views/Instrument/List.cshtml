@model MusicStore.WebUI.Models.InstrumentsListViewModel
@using MusicStore.WebUI.HtmlHelpers

@{
    ViewBag.Title = "Instruments";
}

<div class="container mt-4">

    <!-- SEARCH + SORT BAR -->
    <div class="row mb-3">
        <div class="col-md-6">
            <form method="get">
                <input type="text" name="search" value="@Request.QueryString["search"]"
                       placeholder="Search instruments..." class="form-control" />

                <input type="hidden" name="category" value="@Request.QueryString["category"]" />
                <input type="hidden" name="sort" value="@Request.QueryString["sort"]" />
            </form>
        </div>

        <div class="col-md-6">
            <form method="get">
                <select name="sort" class="form-select" onchange="this.form.submit()">
                    <option value="">Sort by...</option>
                    <option value="price_asc" @(Request.QueryString["sort"] == "price_asc" ? "selected" : "")>Price: Low → High</option>
                    <option value="price_desc" @(Request.QueryString["sort"] == "price_desc" ? "selected" : "")>Price: High → Low</option>
                    <option value="name_asc" @(Request.QueryString["sort"] == "name_asc" ? "selected" : "")>Name: A → Z</option>
                    <option value="name_desc" @(Request.QueryString["sort"] == "name_desc" ? "selected" : "")>Name: Z → A</option>
                </select>

                <input type="hidden" name="category" value="@Request.QueryString["category"]" />
                <input type="hidden" name="search" value="@Request.QueryString["search"]" />
            </form>
        </div>
    </div>

    <!-- PRODUCT GRID -->
    <div class="row">
        @foreach (var p in Model.Instruments)
        {
            <div class="col-md-4 mb-4">
                @Html.Partial("ProductSummary", p)
            </div>
        }
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-end mt-3">
        @Html.PageLinks(Model.PagingInfo,
            x => Url.Action("List", new
            {
                page = x,
                category = Model.CurrentCategory,
                search = Model.SearchTerm,
                sort = Model.CurrentSort
            }))
    </div>

</div>
